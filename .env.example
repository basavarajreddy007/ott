PORT=5000
NODE_ENV=development

# MongoDB — REQUIRED
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/ott-platform?retryWrites=true&w=majority

# JWT — REQUIRED — use long random strings (openssl rand -hex 64)
JWT_SECRET=replace_with_a_long_random_secret
JWT_REFRESH_SECRET=replace_with_another_long_random_secret
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# Cloudinary — REQUIRED for media uploads
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# SMTP / Email — REQUIRED for OTP and notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_google_app_password
EMAIL_FROM=noreply@yourdomain.com
OTP_EXPIRE=10

# Client URL — used for CORS and email links
CLIENT_URL=http://localhost:5173

# Optional — AI features are disabled if not provided
OPENROUTER_API_KEY=

# Optional — payments run in mock mode if not provided
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
